{
  "name": "pulsev2",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "lint": "npm --workspace apps/web run lint",
    "db:setup": "psql -f db/schema.sql",
    "qa:summaries": "bash scripts/qa-summaries.sh",
    "qa:grouping": "node --conditions react-server --import tsx/esm scripts/grouping_regression_check.mjs",
    "qa:audience": "node --import tsx/esm scripts/audience_regression_check.mjs",
    "qa:k12-relevance": "node --import tsx/esm scripts/k12_relevance_regression_check.mjs",
    "qa:newsletter-ranking": "node --import tsx/esm scripts/newsletter_ranking_regression_check.mjs",
    "qa:ranking": "node --import tsx/esm scripts/ranking_regression_check.mjs",
    "qa:newsletter-coverage": "/bin/zsh -lc \"set -a; source .env >/dev/null 2>&1; node --conditions react-server --import tsx/esm scripts/newsletter_coverage_audit.mjs\"",
    "qa:headline": "node --import tsx/esm scripts/headline_regression_check.mjs",
    "qa:source-coverage": "node --conditions react-server --import tsx/esm scripts/source_coverage_regression_check.mjs",
    "qa:homepage-display": "node scripts/homepage_source_display_check.mjs",
    "qa:homepage-topic-dedupe": "node --conditions react-server --import tsx/esm scripts/homepage_topic_dedupe_check.mjs",
    "qa:single-source-audit": "/bin/zsh -lc \"set -a; source .env >/dev/null 2>&1; node --conditions react-server --import tsx/esm scripts/single_source_audit_report.mjs\"",
    "qa:story-quality": "node --import tsx/esm scripts/story_quality_regression_check.mjs",
    "qa:source-family": "node --import tsx/esm scripts/source_family_regression_check.mjs",
    "qa:guardrails": "bash scripts/qa-guardrails.sh"
  }
}
